rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can only read/write their own top-level profile doc.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      // Users can only read/write their own connections subcollection.
      match /connections/{connId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // Users can only read/write their own meetings subcollection.
      match /meetings/{meetingId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }

      // Users can only read/write their own email templates.
      match /emailTemplates/{templateId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // Deny everything else.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
